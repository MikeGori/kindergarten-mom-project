rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper: Is the user a staff member?
    function isStaff() {
      return request.auth != null && 
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'staff';
    }

    // Staff path rules
    match /staff/{staffId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == staffId && isStaff();
    }

    // Children path rules
    match /children/{childId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; // Simplified: in a real app, verify childId or use custom tokens
    }
    
    // Fallback
    match /{allPaths=**} {
      allow read, write: if isStaff();
    }
  }
}
